{
  "typography": {
    "font_family": "'DM Sans', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "font_mono": "'DM Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "scale": {
      "text-xs": "10px",
      "text-sm": "13px",
      "text-base": "15px",
      "text-md": "16px",
      "text-lg": "20px",
      "text-xl": "24px",
      "text-xxl": "29px"
    },
    "line_heights": {
      "body": "1.5",
      "heading": "1.25"
    },
    "font_weights": {
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    }
  },
  "colors": {
    "brand": {
      "brand-red": "#FF3621",
      "brand-red-hover": "#EB1600"
    },
    "semantic": {
      "success": "#2E844A",
      "warning": "#FFAB00",
      "info": "#0176D3",
      "error": "#FF3621"
    },
    "surface": {
      "page": "#F9F7F4",
      "card": "#FFFFFF"
    },
    "text": {
      "primary": "#1B3139"
    }
  },
  "spacing": {
    "space-1": "4px",
    "space-2": "8px",
    "space-3": "12px",
    "space-4": "16px",
    "space-6": "24px",
    "space-8": "32px",
    "space-12": "48px",
    "space-16": "64px"
  },
  "radius": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "pill": "999px",
    "button": "0px"
  },
  "shadows": {
    "sm": "0 1px 2px rgba(27,49,57,0.08)",
    "md": "0 2px 6px rgba(27,49,57,0.12)",
    "lg": "0 8px 24px rgba(27,49,57,0.16)"
  },
  "breakpoints": {
    "tablet": "768px",
    "desktop": "1024px"
  }
}
