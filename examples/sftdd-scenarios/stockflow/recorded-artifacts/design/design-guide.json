{
  "$schema": "https://lakebase-tdd.databricks.com/schemas/design-guide.schema.json",
  "version": 1,
  "project": "StockFlow",

  "typography": {
    "fontFamily": "\"DM Sans\", system-ui, -apple-system, \"Segoe UI\", sans-serif",
    "fontMono": "\"DM Mono\", ui-monospace, monospace",
    "scale": {
      "xs":   { "rem": "0.625rem",  "px": 10, "cssVar": "--text-xs"   },
      "sm":   { "rem": "0.8125rem", "px": 13, "cssVar": "--text-sm"   },
      "base": { "rem": "0.9375rem", "px": 15, "cssVar": "--text-base" },
      "md":   { "rem": "1rem",      "px": 16, "cssVar": "--text-md"   },
      "lg":   { "rem": "1.25rem",   "px": 20, "cssVar": "--text-lg"   },
      "xl":   { "rem": "1.5rem",    "px": 24, "cssVar": "--text-xl"   },
      "xxl":  { "rem": "1.8125rem", "px": 29, "cssVar": "--text-xxl"  }
    },
    "lineHeight": {
      "tight":  { "value": 1.25, "cssVar": "--leading-tight"  },
      "normal": { "value": 1.5,  "cssVar": "--leading-normal" }
    }
  },

  "colors": {
    "brand": {
      "red":       { "value": "#FF3621",              "cssVar": "--color-brand-red"       },
      "redHover":  { "value": "#EB1600",              "cssVar": "--color-brand-red-hover" },
      "redLight":  { "value": "rgba(255,54,33,0.08)", "cssVar": "--color-brand-red-light" }
    },
    "navy": {
      "900": { "value": "#1B3139", "cssVar": "--color-navy-900" },
      "700": { "value": "#1B5162", "cssVar": "--color-navy-700" },
      "500": { "value": "#618794", "cssVar": "--color-navy-500" },
      "400": { "value": "#90A5B1", "cssVar": "--color-navy-400" },
      "300": { "value": "#C4CCD6", "cssVar": "--color-navy-300" },
      "200": { "value": "#E5EAF1", "cssVar": "--color-navy-200" },
      "100": { "value": "#EDF2F8", "cssVar": "--color-navy-100" }
    },
    "background": {
      "white": { "value": "#FFFFFF", "cssVar": "--color-bg-white" },
      "warm":  { "value": "#F9F7F4", "cssVar": "--color-bg-warm"  },
      "cool":  { "value": "#F0F2F5", "cssVar": "--color-bg-cool"  }
    },
    "semantic": {
      "success":      { "value": "#2E844A",             "cssVar": "--color-success"       },
      "successLight": { "value": "rgba(46,132,74,0.1)", "cssVar": "--color-success-light" },
      "warning":      { "value": "#FFAB00",             "cssVar": "--color-warning"       },
      "warningLight": { "value": "rgba(255,171,0,0.12)","cssVar": "--color-warning-light" },
      "info":         { "value": "#0176D3",             "cssVar": "--color-info"          },
      "infoLight":    { "value": "rgba(1,118,211,0.1)", "cssVar": "--color-info-light"    },
      "error":        { "value": "#FF3621",             "cssVar": "--color-error"         },
      "errorLight":   { "value": "rgba(255,54,33,0.08)","cssVar": "--color-error-light"   }
    }
  },

  "spacing": {
    "1":  { "value": "4px",  "cssVar": "--space-1"  },
    "2":  { "value": "8px",  "cssVar": "--space-2"  },
    "3":  { "value": "12px", "cssVar": "--space-3"  },
    "4":  { "value": "16px", "cssVar": "--space-4"  },
    "5":  { "value": "20px", "cssVar": "--space-5"  },
    "6":  { "value": "24px", "cssVar": "--space-6"  },
    "8":  { "value": "32px", "cssVar": "--space-8"  },
    "10": { "value": "40px", "cssVar": "--space-10" },
    "12": { "value": "48px", "cssVar": "--space-12" },
    "16": { "value": "64px", "cssVar": "--space-16" }
  },

  "radius": {
    "none": { "value": "0px",    "cssVar": "--radius-none" },
    "sm":   { "value": "4px",    "cssVar": "--radius-sm"   },
    "md":   { "value": "8px",    "cssVar": "--radius-md"   },
    "lg":   { "value": "12px",   "cssVar": "--radius-lg"   },
    "xl":   { "value": "15px",   "cssVar": "--radius-xl"   },
    "pill": { "value": "9999px", "cssVar": "--radius-pill" }
  },

  "shadows": {
    "sm":     { "value": "0px 2px 8px rgba(27,49,57,0.06)",  "cssVar": "--shadow-sm"     },
    "md":     { "value": "0px 4px 16px rgba(27,49,57,0.08)", "cssVar": "--shadow-md"     },
    "lg":     { "value": "0px 4px 8px rgba(27,49,57,0.04),0px 16px 24px rgba(27,49,57,0.04),0px 32px 40px rgba(27,49,57,0.05)", "cssVar": "--shadow-lg" },
    "navbar": { "value": "0px 4px 20px rgba(27,49,57,0.3)",  "cssVar": "--shadow-navbar" }
  },

  "breakpoints": {
    "mobile":  { "value": "480px",  "cssVar": "--bp-mobile"  },
    "tablet":  { "value": "768px",  "cssVar": "--bp-tablet"  },
    "desktop": { "value": "1024px", "cssVar": "--bp-desktop" }
  },

  "layout": {
    "contentMaxWidth": { "value": "960px", "cssVar": "--content-max-width" },
    "navbarHeight":    { "value": "64px",  "cssVar": "--navbar-height"    }
  },

  "transitions": {
    "fast": { "value": "0.15s ease", "cssVar": "--transition-fast" },
    "base": { "value": "0.2s ease",  "cssVar": "--transition-base" }
  },

  "adherenceContract": {
    "description": "Token-level adherence: every cssVar above must exist on :root in the running app (assertDesignAdherence). Element-level checks: no hardcoded hex/px in inline styles (checkHardcodedValues), all ia.md testids present (checkRequiredSeams), every form/submit surface has role=alert or data-testid matching error|success|message|status (checkFeedbackPresent).",
    "playwrightUsage": "import { assertDesignAdherence } from '@databricks-solutions/lakebase-app-dev-kit/tdd/design-adherence'; import guide from '../.tdd/design/design-guide.json'; test('UI adheres to design guide', async ({ page }) => { await page.goto(process.env.BASE_URL!); await assertDesignAdherence(page, guide); });"
  }
}
