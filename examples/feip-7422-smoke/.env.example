# TDD-workflow smoke configuration , copy to your own env and source it before
# running the orchestrator scripts. These are read from the environment by
# examples/feip-7422-smoke/orchestrator/run-smoke.sh (and the run-to-* scripts);
# nothing here is committed with real values. This file is a template only.
#
#   cp examples/feip-7422-smoke/.env.example ~/lakebase-smoke.env
#   # edit ~/lakebase-smoke.env, then:
#   set -a; source ~/lakebase-smoke.env; set +a
#   examples/feip-7422-smoke/orchestrator/run-smoke.sh --tiers 2

# ── Required for the scaffold step ────────────────────────────────────
# Your Databricks workspace URL. Alternatively, leave this unset and rely on
# a configured ~/.databrickscfg profile (set DATABRICKS_CONFIG_PROFILE below).
export DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com

# Your sandbox GitHub user or org. The smoke creates + uses a repo under it.
export GITHUB_OWNER=<your-github-user-or-org>

# ── Optional ──────────────────────────────────────────────────────────
# Pin the kit to a branch/tag/sha instead of THIS checkout's built dist/.
# Leave unset to test your local working tree (the default).
# export LAKEBASE_KIT_REF=main

# Point the lk resolver at a specific kit install instead of resolving a ref.
# export LAKEBASE_KIT_DIR=/path/to/lakebase-app-dev-kit

# A Databricks CLI profile to use instead of DATABRICKS_HOST.
# export DATABRICKS_CONFIG_PROFILE=<profile-name>

# Auto-answer the pause-at-handoff gates in run-to-navigator.sh /
# run-to-release-engineer.sh (non-interactive / CI). Leave unset to be prompted.
# export LAKEBASE_TDD_AUTO_CONTINUE=1
