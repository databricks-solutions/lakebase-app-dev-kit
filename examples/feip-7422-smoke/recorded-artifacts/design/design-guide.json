{
  "version": "1.0.0",
  "project": "bug-tracker",
  "description": "Design system tokens for the bug tracker application, sourced from Databricks-brand default and GitHub Issues reference",
  "provenance": {
    "brand-colors": "Databricks-brand default",
    "layout-density": "GitHub Issues (github.com/issues)"
  },
  "typography": {
    "fontStack": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', sans-serif",
    "scale": {
      "type-xs": {
        "fontSize": "12px",
        "lineHeight": "1.5",
        "fontWeight": "400",
        "description": "Helper text, timestamps, captions"
      },
      "type-sm": {
        "fontSize": "13px",
        "lineHeight": "1.5",
        "fontWeight": "400",
        "description": "Form labels, secondary information"
      },
      "type-base": {
        "fontSize": "16px",
        "lineHeight": "1.5",
        "fontWeight": "400",
        "description": "Body text, list rows, form fields"
      },
      "type-lg": {
        "fontSize": "18px",
        "lineHeight": "1.6",
        "fontWeight": "500",
        "description": "Subheadings, form section titles"
      },
      "type-xl": {
        "fontSize": "24px",
        "lineHeight": "1.3",
        "fontWeight": "600",
        "description": "Page headings, detail page title"
      },
      "type-mono": {
        "fontSize": "13px",
        "lineHeight": "1.5",
        "fontWeight": "400",
        "fontFamily": "'Monaco', 'Courier New', monospace",
        "description": "Bug identifiers (e.g., #42)"
      }
    }
  },
  "colors": {
    "brand": {
      "--color-brand-red": "#E74C3C"
    },
    "neutral": {
      "--color-neutral-white": "#FFFFFF",
      "--color-neutral-900": "#1A1A1A",
      "--color-neutral-700": "#4A4A4A",
      "--color-neutral-500": "#757575",
      "--color-neutral-300": "#EBEBEB",
      "--color-neutral-200": "#F5F5F5",
      "--color-neutral-100": "#FAFAFA"
    },
    "semantic": {
      "--color-status-open": "#1A73E8",
      "--color-status-closed": "#34A853",
      "--color-status-in-progress": "#EA4335",
      "--color-feedback-error": "#D32F2F",
      "--color-feedback-success": "#388E3C",
      "--color-feedback-warning": "#F57C00"
    },
    "surface": {
      "--color-surface-page": "#FFFFFF",
      "--color-surface-card": "#FFFFFF",
      "--color-surface-hover": "#F5F5F5",
      "--color-surface-focus": "#EBEBEB"
    }
  },
  "spacing": {
    "--space-xs": "4px",
    "--space-sm": "8px",
    "--space-md": "16px",
    "--space-lg": "24px",
    "--space-xl": "32px",
    "--space-2xl": "48px"
  },
  "radius": {
    "--radius-none": "0px",
    "--radius-sm": "2px",
    "--radius-md": "4px",
    "--radius-lg": "8px"
  },
  "shadows": {
    "--shadow-none": "none",
    "--shadow-sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "--shadow-md": "0 4px 6px rgba(0, 0, 0, 0.1)",
    "--shadow-lg": "0 10px 15px rgba(0, 0, 0, 0.1)"
  },
  "breakpoints": {
    "--breakpoint-mobile": "480px",
    "--breakpoint-tablet": "768px",
    "--breakpoint-desktop": "1024px",
    "--breakpoint-wide": "1440px"
  },
  "components": {
    "button-primary": {
      "background": "--color-brand-red",
      "color": "--color-neutral-white",
      "padding": "8px 16px",
      "radius": "--radius-md",
      "font": "16px / 1.5 400",
      "minHeight": "40px",
      "states": {
        "hover": {
          "background": "#EC7063"
        },
        "active": {
          "background": "#C0392B"
        },
        "disabled": {
          "opacity": "0.5"
        }
      }
    },
    "button-secondary": {
      "background": "--color-neutral-200",
      "color": "--color-neutral-900",
      "padding": "8px 16px",
      "radius": "--radius-md",
      "font": "16px / 1.5 500",
      "minHeight": "40px",
      "border": "1px solid --color-neutral-300",
      "states": {
        "hover": {
          "background": "#EBEBEB"
        },
        "active": {
          "background": "#DCDCDC"
        },
        "disabled": {
          "opacity": "0.5"
        }
      }
    },
    "button-link": {
      "background": "transparent",
      "color": "--color-brand-red",
      "padding": "0",
      "font": "16px / 1.5 400",
      "textDecoration": "none",
      "states": {
        "hover": {
          "textDecoration": "underline"
        },
        "disabled": {
          "opacity": "0.5"
        }
      }
    },
    "input-text": {
      "background": "--color-surface-card",
      "border": "1px solid --color-neutral-300",
      "padding": "8px",
      "radius": "--radius-sm",
      "font": "16px / 1.5 400",
      "states": {
        "focus": {
          "borderColor": "--color-brand-red",
          "boxShadow": "0 0 0 3px rgba(231, 76, 60, 0.1)"
        },
        "error": {
          "borderColor": "--color-feedback-error"
        },
        "disabled": {
          "opacity": "0.5",
          "backgroundColor": "--color-neutral-100"
        }
      }
    },
    "textarea": {
      "background": "--color-surface-card",
      "border": "1px solid --color-neutral-300",
      "padding": "8px",
      "radius": "--radius-sm",
      "font": "16px / 1.5 400",
      "minHeight": "120px",
      "states": {
        "focus": {
          "borderColor": "--color-brand-red",
          "boxShadow": "0 0 0 3px rgba(231, 76, 60, 0.1)"
        },
        "error": {
          "borderColor": "--color-feedback-error"
        }
      }
    },
    "label": {
      "font": "13px / 1.5 600",
      "color": "--color-neutral-900",
      "marginBottom": "4px"
    },
    "helper-text": {
      "font": "12px / 1.5 400",
      "color": "--color-neutral-700",
      "marginTop": "4px"
    },
    "error-text": {
      "font": "12px / 1.5 400",
      "color": "--color-feedback-error",
      "marginTop": "4px"
    },
    "status-pill": {
      "padding": "4px 8px",
      "radius": "--radius-md",
      "font": "13px / 1.5 500"
    },
    "status-pill-open": {
      "background": "rgba(26, 115, 232, 0.15)",
      "color": "--color-status-open"
    },
    "status-pill-closed": {
      "background": "rgba(52, 168, 83, 0.15)",
      "color": "--color-status-closed"
    },
    "card": {
      "background": "--color-surface-card",
      "border": "1px solid --color-neutral-300",
      "padding": "24px",
      "radius": "--radius-md",
      "shadow": "--shadow-md",
      "marginBottom": "24px"
    },
    "empty-state": {
      "background": "--color-surface-card",
      "padding": "32px",
      "radius": "--radius-md",
      "border": "1px dashed --color-neutral-300",
      "font": "16px / 1.5 400",
      "color": "--color-neutral-700"
    }
  }
}
