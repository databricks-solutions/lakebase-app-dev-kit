    "pill": "12px"
  },
  "shadows": {
    "soft": "0 2px 8px rgba(27, 49, 57, 0.08)"
  },
  "breakpoints": {
    "mobile": "320px",
    "tablet": "768px",
    "desktop": "1024px"
  },
  "layout": {
    "maxContentWidth": "960px",
