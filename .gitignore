# Runtime per-run config snapshot (rebuilt every drive; never a tracked artifact).
# NB: this replaces an org-init `*conf*.json` glob that was catastrophically
# over-broad , it silently dropped every corpus/data json with "conf" in its name
# (AC files like *-confirmed.json, *-nonconforming-*.json, and client tsconfig.json
# in recorded code trees), so shipped scenario corpora were missing ACs. Anchor to
# the actual runtime file by exact basename instead.
run-config.json
# Turn-recorder runtime state (per-capture; not a shipped corpus artifact).
.recorder-state.json
.DS_Store
__pycache__
.idea/

# Project-specific
node_modules/
dist/
.env
.env.*
!.env.example
!.env.kit.example
!.env.template.test.config
*.vsix
*.log
coverage/
.vitest/
.venv-live-tests/
.tools-live-tests/

# devhub-vendored skills are install-time products; pinned in devhub.lock.
skills/databricks-core/
skills/databricks-lakebase/
tests/agent-capability/timings.jsonl

# Local, non-shipped scenario recordings (no tracked scenario.json manifest, so
# not part of the replay corpus). These are on-disk scratch from prior captures;
# once the over-broad `*conf*.json` glob was removed they became visible to git,
# and we keep them out of any accidental `git add -A`. Anchored to the EXACT
# directory paths (NOT a glob) so the shipped `stockflow/` corpus is untouched and
# this can never over-match. To promote one to a shipped scenario, git add -f it.
examples/sftdd-scenarios/stockflow-live/
examples/sftdd-scenarios/stockflow-s3-selfheal-verify/
