{
  "name": "@databricks-solutions/lakebase-app-dev-kit",
  "version": "0.3.0-beta.0",
  "description": "Lakebase-backed application development kit – shared scripts, agent skills (SCM today, TDD next), MCP server, and OpenAI Foundry tool spec. Consumed by lakebase-scm-extension and coding agents (Claude Code, Claude Desktop, OpenAI Codex, Cursor, Databricks Genie Code).",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "scripts",
    "skills",
    "templates",
    "install.sh",
    "README.md",
    "LICENSE.md"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/databricks-solutions/lakebase-app-dev-kit"
  },
  "main": "./dist/scripts/index.cjs",
  "module": "./dist/scripts/index.js",
  "types": "./dist/scripts/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/scripts/index.d.ts",
        "default": "./dist/scripts/index.js"
      },
      "require": {
        "types": "./dist/scripts/index.d.cts",
        "default": "./dist/scripts/index.cjs"
      }
    },
    "./github": {
      "import": {
        "types": "./dist/scripts/github/index.d.ts",
        "default": "./dist/scripts/github/index.js"
      },
      "require": {
        "types": "./dist/scripts/github/index.d.cts",
        "default": "./dist/scripts/github/index.cjs"
      }
    },
    "./lakebase": {
      "import": {
        "types": "./dist/scripts/lakebase/index.d.ts",
        "default": "./dist/scripts/lakebase/index.js"
      },
      "require": {
        "types": "./dist/scripts/lakebase/index.d.cts",
        "default": "./dist/scripts/lakebase/index.cjs"
      }
    },
    "./git": {
      "import": {
        "types": "./dist/scripts/git/index.d.ts",
        "default": "./dist/scripts/git/index.js"
      },
      "require": {
        "types": "./dist/scripts/git/index.d.cts",
        "default": "./dist/scripts/git/index.cjs"
      }
    },
    "./util": {
      "import": {
        "types": "./dist/scripts/util/index.d.ts",
        "default": "./dist/scripts/util/index.js"
      },
      "require": {
        "types": "./dist/scripts/util/index.d.cts",
        "default": "./dist/scripts/util/index.cjs"
      }
    }
  },
  "bin": {
    "lakebase-get-connection": "./dist/scripts/lakebase/get-connection.cli.js",
    "lakebase-schema-diff": "./dist/scripts/lakebase/schema-diff.cli.js",
    "lakebase-schema-migrate": "./dist/scripts/lakebase/schema-migrate.cli.js",
    "lakebase-github-token": "./dist/scripts/github/auth.cli.js",
    "lakebase-adopt-tdd": "./dist/scripts/lakebase/adopt-tdd.cli.js",
    "lakebase-create-project": "./dist/scripts/lakebase/create-project.cli.js",
    "lakebase-infra-runner": "./dist/scripts/lakebase/infra-runner.cli.js",
    "lakebase-update-commands": "./dist/scripts/lakebase/update-commands.cli.js",
    "lakebase-cut-backup": "./dist/scripts/lakebase/cut-backup.cli.js",
    "lakebase-detect-language": "./dist/scripts/lakebase/detect-language.cli.js",
    "lakebase-resolve-profile": "./dist/scripts/lakebase/resolve-profile.cli.js",
    "lakebase-ci-app-endpoint": "./dist/scripts/lakebase/ci-app-endpoint.cli.js",
    "lakebase-ci-resolve-branch": "./dist/scripts/lakebase/ci-resolve-branch.cli.js",
    "lakebase-branch": "./dist/scripts/lakebase/branch.cli.js",
    "lakebase-doctor": "./dist/scripts/lakebase/doctor.cli.js",
    "lakebase-scm-state": "./dist/scripts/lakebase/scm-state.cli.js",
    "lakebase-scm-claim-feature-branch": "./dist/scripts/lakebase/scm-claim-feature.cli.js",
    "lakebase-scm-adopt-state": "./dist/scripts/lakebase/scm-adopt-state.cli.js",
    "lakebase-scm-abandon-feature": "./dist/scripts/lakebase/scm-abandon-feature.cli.js",
    "lakebase-scm-prepare-pr": "./dist/scripts/lakebase/scm-prepare-pr.cli.js",
    "lakebase-scm-wait-ci": "./dist/scripts/lakebase/scm-wait-ci.cli.js",
    "lakebase-scm-merge": "./dist/scripts/lakebase/scm-merge.cli.js",
    "lakebase-scm-recover-orphans": "./dist/scripts/lakebase/scm-recover-orphans.cli.js",
    "lakebase-scm-doctor": "./dist/scripts/lakebase/scm-doctor.cli.js",
    "lakebase-scm-feature-branch": "./dist/scripts/lakebase/scm-feature-branch.cli.js",
    "lakebase-pr": "./dist/scripts/github/pr.cli.js",
    "lakebase-feature-status": "./dist/scripts/tdd/feature-status.cli.js",
    "lakebase-tdd-human-proxy": "./dist/scripts/tdd/human-proxy.cli.js",
    "lakebase-tdd-intake": "./dist/scripts/tdd/intake.cli.js",
    "lakebase-tdd-deploy": "./dist/scripts/tdd/deploy.cli.js",
    "lakebase-tdd-gate-conformance": "./dist/scripts/tdd/gate-conformance.cli.js",
    "lakebase-tdd-log": "./dist/scripts/tdd/agent-log.cli.js",
    "lakebase-tdd-agent-model": "./dist/scripts/tdd/agent-models.cli.js",
    "lakebase-tdd-pipeline": "./dist/scripts/tdd/story-pipeline.cli.js",
    "lakebase-tdd-experiment": "./dist/scripts/tdd/story-experiment.cli.js",
    "lakebase-tdd-cycle": "./dist/scripts/tdd/cycle.cli.js",
    "lakebase-tdd-test-list": "./dist/scripts/tdd/test-list.cli.js",
    "lakebase-tdd-drive": "./dist/scripts/tdd/drive.cli.js",
    "lakebase-tdd-spike": "./dist/scripts/tdd/spike.cli.js",
    "lakebase-tdd-new-migration": "./dist/scripts/lakebase/new-migration.cli.js",
    "lakebase-tdd-collapse-heads": "./dist/scripts/lakebase/collapse-heads.cli.js",
    "lakebase-mcp-server": "./dist/apps/mcp-server/index.js"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "node scripts/prepare.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "sync:devhub": "tsx scripts/sync-devhub-skills.ts",
    "check:devhub": "tsx scripts/sync-devhub-skills.ts --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "bash scripts/run-live-tests.sh"
  },
  "dependencies": {
    "@databricks/appkit": "*",
    "@databricks/lakebase": "*",
    "adm-zip": "^0.5.16",
    "find-java-home": "^2.0.0",
    "octokit": "^4.0.0",
    "pg": "^8.20.0",
    "tar": "^7.4.3",
    "tree-kill": "^1.2.2",
    "tweetsodium": "^0.0.5"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/tar": "^6.1.13",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
